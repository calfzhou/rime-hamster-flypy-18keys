spacepreeditStateForegroundStyle:
  text: "// JavaScript\nfunction getText() {\n  const candidate = $getRimeCandidates();\n
    \ \n  // \u5224\u65AD candidate \u662F\u5426\u5B58\u5728\n  if (candidate && candidate.length
    > 0) {\n    const result = candidate.map(c => c.text).join(\" \");\n    if (result.length
    > 11) {\n      return result.slice(0,8) + \"...\";\n    }\n    return result;\n
    \ }\n  return \"\";\n}"
  normalColor: ffffff
  highlightColor: ffffff
  fontSize: 1em
  center:
    y: 0.8
