cnenButtonForegroundStyle1:
  text: "// JavaScript\nfunction getText() {\n  if ($getRimeOptionState(\"s2s\"))
    {\n      return \"\u7B80\";\n  } else if ($getRimeOptionState(\"s2t\")) {\n      return
    \"\u7E41\";\n  } else if ($getRimeOptionState(\"s2hk\")) {\n      return \"\u6E2F\";\n
    \ } else if ($getRimeOptionState(\"s2tw\")) {\n      return \"\u53F0\";\n  } else
    {\n      return \"\u7B80\";\n  }\n}"
  fontSize: 1.75em
  normalColor: E5E5EA
  highlightColor: ffffff
  center:
    y: 0.5
cnenButtonForegroundStyle2:
  text: "// JavaScript\nfunction getText() {\n  return $getRimeOptionState(\"chinese_english\")
    ? \"\u7FFB\" : \"\u8BD1\";\n}"
  fontSize: 1.75em
  normalColor: E5E5EA
  highlightColor: ffffff
  center:
    y: 0.5
cnenButtonForegroundStyle3:
  text: "// JavaScript\nfunction getText() {\n  return $getRimeOptionState(\"chaifen_switch\")
    ? \"\u62C6\" : \"\u5173\";\n}"
  fontSize: 1.75em
  normalColor: E5E5EA
  highlightColor: ffffff
  center:
    y: 0.5
cnenButtonForegroundStyle4:
  text: "// JavaScript\nfunction getText() {\n  return $getRimeOptionState(\"super_tips\")
    ? \"\u63D0\" : \"\u5173\";\n}"
  fontSize: 1.75em
  normalColor: E5E5EA
  highlightColor: ffffff
  center:
    y: 0.5
cnenButtonForegroundStyle5:
  text: "// JavaScript\nfunction getText() {\n  return $getRimeOptionState(\"prediction\")
    ? \"\u9884\" : \"\u6D4B\";\n}"
  fontSize: 1.75em
  normalColor: E5E5EA
  highlightColor: ffffff
  center:
    y: 0.5
